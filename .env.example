# Optional. Without this key, the POC reads Google's public Maps preview payload.
# With it, Places API (New) enriches pages with reviews and additional place data.
GOOGLE_MAPS_API_KEY=

# Required for the persistent generation pipeline.
DATABASE_URL=
APIFY_PERSONAL_API_TOKEN=

# Local Blob authentication. Vercel deployments can use BLOB_STORE_ID and OIDC.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Required for menu management sessions. Generate at least 32 random characters.
MENU_SESSION_SECRET=

# Required for rights-cleared menu sources. This must address a private Blob store,
# separate from the public restaurant media store above.
MENU_BLOB_READ_WRITE_TOKEN=

# Required in production. The isolated worker receives raw bytes as
# application/octet-stream, scans and normalizes them, and returns clean,
# safeToProcess, scanner, version, transformedBase64, dimensions/pageCount,
# perceptualHash, and transformations as JSON.
MENU_DOCUMENT_PROCESSOR_URL=
MENU_DOCUMENT_PROCESSOR_TOKEN=

# Development only. Enables the deterministic EICAR signature check when no
# isolated processor is configured. Never enable this in production.
MENU_ALLOW_DEVELOPMENT_SCANNER=false

# Authorizes the retention/deletion sweep endpoint.
CRON_SECRET=
