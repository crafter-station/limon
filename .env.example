# Optional. Without this key, the POC reads Google's public Maps preview payload.
# With it, Places API (New) enriches pages with reviews and additional place data.
GOOGLE_MAPS_API_KEY=

# Required for the persistent generation pipeline.
DATABASE_URL=
APIFY_PERSONAL_API_TOKEN=

# Local Blob authentication. Vercel deployments can use BLOB_STORE_ID and OIDC.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Optional locally. Vercel deployments authenticate AI Gateway with OIDC.
AI_GATEWAY_API_KEY=

# Optional override. Defaults to google/gemini-2.5-flash-lite.
MENU_VISION_MODEL=
